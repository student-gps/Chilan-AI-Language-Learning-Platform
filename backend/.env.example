# ==========================================
# 1. 数据库配置 (Database)
# ==========================================
APP_DATABASE_URL=

# ==========================================
# 2. 内容生成与嵌入总开关 (LLM Routing)
# ==========================================
LLM_CONTENT_PROVIDER=gemini
LLM_EMBED_PROVIDER=gemini

# ==========================================
# 3. 通用大模型 API Keys (General LLM Keys)
# ==========================================
LLM_OPENAI_API_KEY=
LLM_GEMINI_API_KEY=
LLM_ZHIPU_API_KEY=
LLM_VOYAGE_API_KEY=
LLM_DEEPSEEK_API_KEY=
LLM_ALI_API_KEY=
MEDIA_LUMA_API_KEY=

# ==========================================
# 4. 内容生成模型 ID (Content Build Models)
# ==========================================
LLM_CONTENT_GEMINI_MODEL_ID=gemini-2.5-pro
LLM_CONTENT_CLAUDE_MODEL_ID=claude-3-5-sonnet-latest
LLM_CONTENT_DOUBAO_ENDPOINT_ID=

# ==========================================
# 5. Embedding 模型配置 (Embedding Models)
# ==========================================
LLM_EMBED_GEMINI_MODEL_ID=gemini-embedding-001
LLM_EMBED_OPENAI_MODEL_ID=text-embedding-3-large
LLM_EMBED_DOUBAO_MODEL_ID=
LLM_EMBED_ZHIPU_MODEL_ID=embedding-3
LLM_EMBED_VOYAGE_MODEL_ID=voyage-4-large
LLM_EMBED_ALI_MODEL_ID=text-embedding-v4

# ==========================================
# 6. Content Builder 微调参数 (Content Builder Tuning)
# ==========================================
CONTENT_TASK1_PINYIN_BATCH_SIZE=3
CONTENT_TASK1_PINYIN_BATCH_CHAR_LIMIT=600
CONTENT_TASK1_TRANSLATION_REPAIR_BATCH_SIZE=6
CONTENT_TASK2_EXAMPLE_BATCH_SIZE=3
CONTENT_TASK2_WORD_QUIZ_BATCH_SIZE=4

# ==========================================
# 7. 语音判题与 ASR 配置 (Speech Practice & ASR)
# ==========================================
ASR_PROVIDER=openai
ASR_MAX_AUDIO_BYTES=10485760
ASR_OPENAI_MODEL=whisper-1
ASR_OPENAI_API_KEY=
PRACTICE_SPEECH_QUIZ_MIN=3
PRACTICE_SPEECH_QUIZ_MAX=5
PRACTICE_SPEECH_QUIZ_TARGET=4
PRACTICE_VOICE_ALLOW_PARAPHRASE=true
PRACTICE_VOICE_PASS_THRESHOLD=0.88
PRACTICE_VOICE_REVIEW_THRESHOLD=0.78
PRACTICE_VOICE_MIN_ASR_CONFIDENCE=0.60
PRACTICE_VOICE_MAX_ATTEMPTS=3
PRACTICE_VOICE_MAX_DURATION_SEC=15

# ==========================================
# 8. 腾讯云 TTS 配置 (Tencent TTS)
# ==========================================
TTS_TENCENT_SECRET_ID=
TTS_TENCENT_SECRET_KEY=
TTS_TENCENT_DEFAULT_VOICE_TYPE=501002
TTS_TENCENT_ROLE_VOICE_MAP_JSON=
TTS_TENCENT_SENTENCE_GAP_MS=300

# ==========================================
# 9. 腾讯云 COS 媒体存储配置 (Tencent COS)
# ==========================================
STORAGE_COS_SECRET_ID=
STORAGE_COS_SECRET_KEY=
STORAGE_COS_REGION=
STORAGE_COS_BUCKET=
STORAGE_COS_PUBLIC_BASE_URL=
STORAGE_COS_USE_SIGNED_URL=true
STORAGE_COS_SIGNED_URL_EXPIRES_SECONDS=3600

# ==========================================
# 10. 邮件服务配置 (Mail)
# ==========================================
MAIL_PROVIDER=resend
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_FROM=
MAIL_SMTP_PORT=587
MAIL_SMTP_SERVER=smtp.gmail.com
MAIL_SMTP_USE_TLS=true
MAIL_SMTP_USE_SSL=false
MAIL_RESEND_API_KEY=
MAIL_RESEND_FROM=
MAIL_RESEND_AUDIENCE=

# ==========================================
# 11. 登录、跨域与安全配置 (Auth, CORS, Security)
# ==========================================
AUTH_GOOGLE_CLIENT_ID=
AUTH_APPLE_CLIENT_ID=
SECURITY_JWT_SECRET=
SECURITY_JWT_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=1440
APP_CORS_ORIGINS=http://localhost:5173

# ==========================================
# 12. 前端构建变量 (Frontend Build Vars)
# ==========================================
VITE_APP_API_BASE_URL=
VITE_AUTH_GOOGLE_CLIENT_ID=
