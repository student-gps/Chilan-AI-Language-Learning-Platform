  "teaching_materials": {
    "lesson_flow": [],
    "notes_on_text": [
      {
        "title": "Usage of 'and' to show result",
        "text": "..., and she lost her way. ……因此她迷路了。句中的and当“所以”讲,表示结果。",
        "translation": "Here, 'and' is used to indicate a result, meaning 'therefore' or 'so'."
      },
      {
        "title": "Phrases: 'said to herself'",
        "text": "she said to herself, 她心中暗想。",
        "translation": "'Said to herself' means to think something without speaking it aloud."
      }
    ],
    "grammar_sections": [
      {
        "title": "Adverb Formation from Adjectives",
        "explanation": "Many adverbs are formed by adding '-ly' to an adjective. Adverbs describe how, when, or where an action is performed. For example, 'quick' (adjective) becomes 'quickly' (adverb).",
        "examples": [
          {
            "text": "quick -> quickly",
            "translation": "快的 -> 快地"
          },
          {
            "text": "pleasant -> pleasantly",
            "translation": "愉快的 -> 愉快地"
          },
          {
            "text": "careful -> carefully",
            "translation": "小心的 -> 小心地"
          }
        ]
      }
    ]
  },
