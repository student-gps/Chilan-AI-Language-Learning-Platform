    "grammar_sections": [
      {
        "title": "The Past Simple Tense",
        "explanation": "The Past Simple tense is used to describe actions or states that happened at a specific time in the past and are now finished. Regular verbs form the past simple by adding '-ed' or '-d' to the base form (e.g., 'answer' -> 'answered', 'telephone' -> 'telephoned'). Irregular verbs have unique past simple forms (e.g., 'say' -> 'said', 'do' -> 'did').",
        "examples": [
          {
            "text": "He telephoned me four times yesterday.",
            "translation": "šĽĖśė®Ś§©ÁĽôśąĎśČďšļÜ4ś¨°ÁĒĶŤĮĚ„Äā"
