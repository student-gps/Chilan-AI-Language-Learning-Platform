      {
        "segment_id": "line_walkthrough",
        "title": "Exploring 'A Walk Through the Woods'",
        "description": "Go through Lesson 143 line by line. Explain new vocabulary (e.g., 'surround', 'beauty spot', 'litter', 'prosecute') and discuss the narrative. Pay attention to the 'Notes on the text' for specific linguistic points like noun clauses and the meaning of 'said' on a sign. Discuss the irony in the listening question's answer."
      },
      {
        "segment_id": "pattern_focus",
        "title": "Mastering Present Perfect and Future Passive",
        "description": "Focus on Lesson 144's core patterns: 'Hasn't anyone [verb] [object] yet?' and the answers 'It has already been [past participle]!' or 'It hasn't been [past participle] yet. It will be [past participle] soon!'. Explain the structure, usage, and common scenarios for these passive constructions. Use examples from the pattern drills."
      },
      {
        "segment_id": "vocabulary_focus",
        "title": "Key Vocabulary for Description and Action",
        "description": "Review and expand on the vocabulary from both lessons. For Lesson 143, focus on descriptive words related to nature and pollution. For Lesson 144, emphasize the verbs used in the passive voice drills (e.g., 'repair', 'correct', 'catch', 'air', 'clean') and their past participles."
      },
      {
        "segment_id": "guided_practice",
        "title": "Applying Passive Voice and New Words",
        "description": "Lead students through guided practice exercises. This includes answering questions about Lesson 143, and practicing the passive voice patterns from Lesson 144 by creating new sentences or completing given prompts. Encourage students to use the new vocabulary in their responses."
      }
    ]
  },
