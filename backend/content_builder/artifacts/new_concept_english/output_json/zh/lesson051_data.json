  "teaching_materials": {
    "lesson_flow": [],
    "notes_on_text": [
      {
        "title": "Direct Speech",
        "text": "'I have just arrived in Scotland... a Youth Hostel.' This is an example of direct speech. Direct speech is a way of representing spoken language in written form in English. The actual words spoken are placed within quotation marks, and punctuation marks at the end of the sentence are also placed within the quotation marks.",
        "translation": "“我刚到苏格兰,我现住在一家青年招待所。”这是一个直接引语的例子。直接引语是英文中用书面语的形式来表示口语的方式,实际讲的话要放在引号之间,句尾的标点符号也要放在引号之内。"
      },
      {
        "title": "The Y.H.A.",
        "text": "The Y.H.A. = the Youth Hostels Association. The Youth Hostels Association. A Youth Hostel is a type of inexpensive accommodation for young people participating in outdoor adventure holidays. These youth hostels operate on a membership basis; one must first join the Y.H.A. to be eligible for its services.",
        "translation": "the Y.H.A. = the Youth Hostels Association 青年招待所协会。简称“青招协”。a Youth Hostel 是一种为参加野外探险度假活动的青年人提供廉价住宿的招待所。这种青年招待所实行会员制,首先要加入“青招协”才有资格享受这种待遇。"
      },
      {
        "title": "Speak up",
        "text": "Speak up means to speak louder.",
        "translation": "speak up, 大声地说。"
      },
      {
        "title": "Letter Closings",
        "text": "Love, Jimmy. Yours, Jimmy. These are common closing remarks used in correspondence between friends.",
        "translation": "Love, Jimmy. 爱你的吉米。 Yours, Jimmy (你的,吉米)。这是朋友间通信时常用的结束语。"
      },
      {
        "title": "Tag Questions",
        "text": "He doesn't say very much, does he? This is an English tag question, which consists of two parts: a statement followed by a short question after a comma. Tag questions can be used to confirm one's judgment, obtain factual information, or express surprise or anger. If the first part (statement) is affirmative, the tag question should be negative; if the first part is negative, the tag question should be affirmative.",
        "translation": "这是英文中的反意疑问句,它是由两部分组成的,前面是一个陈述句,逗号之后是一个简略问句。反意疑问句可以用来确认自己的判断,获取真实的信息,还可以用来表示惊讶、愤怒等感情。如果前一部分陈述句是肯定形式,简略问句就要用否定形式;如果前一部分是否定形式,后一部分则用肯定形式。"
      }
    ],
    "grammar_sections": [
      {
        "title": "Reported Speech (Indirect Speech)",
        "explanation": "Reported speech is used to convey what someone else said without using their exact words. The main verb in the reporting clause (e.g., 'He says...') often determines the tense changes in the reported clause. When the reporting verb is in the present tense, the tense in the reported clause usually remains the same as in direct speech. For example, 'I am tired' becomes 'He says he is tired.'",
        "examples": [
          {
            "text": "He says he's just arrived in Scotland.",
            "translation": "他说他刚到苏格兰。"
          },
          {
            "text": "She says she needs a haircut.",
            "translation": "她说她需要理发。"
          }
        ]
      },
      {
        "title": "Direct Speech",
        "explanation": "Direct speech uses the exact words of the speaker, enclosed in quotation marks. It's often used in dialogues to make conversations more vivid.",
        "examples": [
          {
            "text": "'I have just arrived in Scotland.'",
            "translation": "“我刚到苏格兰。”"
          },
          {
            "text": "'I'll write a letter soon.'",
            "translation": "“我很快会写信的。”"
          }
        ]
      },
      {
        "title": "Tag Questions",
        "explanation": "Tag questions are short questions added to the end of a statement. They are used to ask for confirmation or to express an opinion. If the main statement is positive, the tag is negative, and vice versa. The auxiliary verb in the tag matches the auxiliary verb in the main statement.",
        "examples": [
          {
            "text": "He doesn't say very much, does he?",
            "translation": "他没写许多,是吗?"
          },
          {
            "text": "You are Penny, aren't you?",
            "translation": "你是彭妮,不是吗?"
          }
        ]
      }
    ]
  },
  "explanation_plan": {
    "target_audience": "Chinese speakers learning English",
    "segments": [
      {
        "segment_id": "scene_setup",
        "title": "Lesson Introduction & Context",
        "description": "Introduce Lesson 101, 'A card from Jimmy'. Set the scene with Grandmother and Penny, explaining they are reading a postcard. Present the main listening question to guide students' initial understanding of the dialogue."
      },
      {
        "segment_id": "line_walkthrough",
        "title": "Dialogue Analysis & Key Phrases",
        "description": "Go through the dialogue line by line. Explain the meaning of each sentence, focusing on new vocabulary and expressions like 'Youth Hostel', 'Y.H.A.', 'speak up', and 'Love, Jimmy'. Highlight instances of direct speech and how Penny reports Jimmy's words, laying the groundwork for reported speech."
      },
      {
        "segment_id": "pattern_focus",
        "title": "Mastering Reported Speech: 'He says he...'",
        "description": "Introduce the core grammar point: reported speech, specifically the pattern 'He says he...' (or 'She says she...', 'They say they...'). Explain how to transform direct statements into reported speech when the reporting verb is in the present tense. Utilize the pattern drills from Lesson 102, demonstrating how to combine the reporting clause with various reported actions/states (e.g., 'is tired', 'has a cold', 'needs a haircut', 'will wait')."
      },
      {
        "segment_id": "vocabulary_focus",
        "title": "Vocabulary Expansion",
        "description": "Review all new words and expressions from both Lesson 101 and Lesson 102. For each word, provide pronunciation, part of speech, and translation. Group related words (e.g., ailments like 'headache', 'earache') to aid memorization. Emphasize practical usage in the context of reported speech."
      },
      {
        "segment_id": "guided_practice",
        "title": "Application & Practice",
        "description": "Guide students through the writing exercises from Lesson 102. Work together on converting direct speech to indirect speech (Exercise A) and constructing sentences using the 'He says he...' pattern with the provided table and phrases (Exercise B). Encourage students to create their own sentences to reinforce understanding and build confidence."
      }
    ]
  },
