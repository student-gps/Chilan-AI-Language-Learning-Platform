    "lesson_flow": [
      {
        "segment_id": "introduction",
        "title": "Introduction to Mrs. Smith's Kitchen",
        "description": "Introduce the lesson's theme: describing objects and their locations in a room. Highlight the 'There is' structure."
      },
      {
        "segment_id": "vocabulary_preview",
        "title": "New Words and Expressions",
        "description": "Go through the new vocabulary from Lesson 25 and 26, focusing on nouns for household items and prepositions of place."
      },
      {
        "segment_id": "text_analysis",
        "title": "Understanding the Passage: Mrs. Smith's Kitchen",
        "description": "Read and analyze the passage line by line, paying attention to the use of 'There is/are', prepositions like 'on the right/left', 'in the middle of', and descriptive adjectives."
      },
      {
        "segment_id": "grammar_focus",
        "title": "Key Grammar: 'There is' and Articles 'a'/'the'",
        "description": "Explain the 'There is' structure for indicating existence. Discuss the rules for using indefinite article 'a' (first mention) and definite article 'the' (subsequent mention or specific item)."
      },
      {
